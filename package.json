{
  "name": "nodejs-authentication-app",
  "version": "1.0.0",
  "description": "Node.js Authentication Web Application with MongoDB, automated testing, and CI/CD pipeline",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "mocha tests/unit/**/*.test.js",
    "test:integration": "mocha tests/integration/**/*.test.js",
    "test:report": "mocha tests/**/*.test.js --reporter mochawesome"
  },
  "keywords": [
    "authentication",
    "nodejs",
    "express",
    "mongodb",
    "testing",
    "jenkins"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "mocha": "^10.2.0",
    "chai": "^4.3.10",
    "selenium-webdriver": "^4.15.0",
    "chromedriver": "^119.0.0",
    "mochawesome": "^7.1.3",
    "nodemon": "^3.0.1"
  }
}
